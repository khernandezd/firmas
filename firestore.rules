rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isRegisteredUser() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function signatureBaseFieldsAreValid() {
      return request.resource.data.keys().hasAll(['image', 'userId', 'timestamp'])
        && request.resource.data.image is string
        && request.resource.data.image.size() > 0
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.timestamp is string;
    }

    function pdfSignatureFieldsAreValid() {
      return request.resource.data.keys().hasOnly(['image', 'userId', 'timestamp', 'page', 'x', 'y', 'width', 'height'])
        && request.resource.data.page is int
        && request.resource.data.page > 0
        && request.resource.data.x is number
        && request.resource.data.y is number
        && request.resource.data.width is number
        && request.resource.data.height is number
        && request.resource.data.x >= 0
        && request.resource.data.y >= 0
        && request.resource.data.width > 0
        && request.resource.data.height > 0
        && request.resource.data.x <= 1
        && request.resource.data.y <= 1
        && request.resource.data.width <= 1
        && request.resource.data.height <= 1
        && request.resource.data.x + request.resource.data.width <= 1
        && request.resource.data.y + request.resource.data.height <= 1;
    }

    function htmlSignatureFieldsAreValid() {
      return request.resource.data.keys().hasOnly(['image', 'userId', 'timestamp', 'xPct', 'yPct', 'wPct'])
        && request.resource.data.xPct is number
        && request.resource.data.yPct is number
        && request.resource.data.wPct is number
        && request.resource.data.xPct >= 0
        && request.resource.data.yPct >= 0
        && request.resource.data.wPct > 0
        && request.resource.data.xPct <= 100
        && request.resource.data.yPct <= 100
        && request.resource.data.wPct <= 100;
    }

    function signaturePayloadIsValid() {
      return isSignedIn()
        && signatureBaseFieldsAreValid()
        && (pdfSignatureFieldsAreValid() || htmlSignatureFieldsAreValid());
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /artifacts/{appId}/public/data/shared_docs/{docId} {
      allow read: if true;
      allow create, delete: if isRegisteredUser();
      allow update: if isRegisteredUser();

      match /signatures/{sigId} {
        allow read: if true;
        allow create: if signaturePayloadIsValid()
          && sigId == request.auth.uid
          && !exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/shared_docs/$(docId)/signatures/$(sigId));
        allow update: if signaturePayloadIsValid()
          && sigId == request.auth.uid
          && resource.data.userId == request.auth.uid;
        allow delete: if isRegisteredUser();
      }
    }

    match /artifacts/{appId}/users/{userId}/signatures/{sigId} {
      allow read, create, update, delete: if isOwner(userId);
    }
  }
}